    "postprocessing": "6.39.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "three": "0.185.1",
    "three-mesh-bvh": "0.9.13",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "^5.7.0",
    "vite": "8.1.5"
  },
  "pnpm": {
    "overrides": {
